# --- Provider switch ---
# "github" = GitHub Models (free with Copilot Pro)
# "openai" = OpenAI directly
LLM_PROVIDER=github

# GitHub Personal Access Token (github.com/settings/tokens)
# Required when LLM_PROVIDER=github
GITHUB_TOKEN=github_pat_...

# OpenAI API key
# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Model override (optional)
# github provider defaults to: gpt-4o-mini
# openai provider defaults to: gpt-4o
# LLM_MODEL=gpt-4o

# Tavily search API — optional but recommended for real-world grounding
# Free tier: 1000 searches/month — get key at app.tavily.com
# TAVILY_API_KEY=tvly-...
